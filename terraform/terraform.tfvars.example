aws_region  = "us-east-1"
environment = "production"

# Database
db_username = "chesslens"
db_password = "CHANGE_ME"

# App secrets
jwt_secret           = "CHANGE_ME"
google_client_id     = "CHANGE_ME"
google_client_secret = "CHANGE_ME"
openrouter_key       = ""

# URLs (set after first deploy to get ALB/CloudFront domains)
frontend_url        = "https://d123456.cloudfront.net"
google_redirect_url = "http://alb-dns/api/v1/auth/google/callback"

# ECS sizing (cost-optimized defaults)
api_cpu    = 256
api_memory = 512

worker_cpu    = 512
worker_memory = 1024

# Aurora Serverless v2
db_min_capacity = 0.5
db_max_capacity = 16

# ElastiCache Serverless
elasticache_max_memory_gb = 1
